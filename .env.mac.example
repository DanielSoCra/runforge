# === Mac Mini Environment ===
# Copy to .env.mac and fill in values:  cp .env.mac.example .env.mac

# Dashboard port binding — exposed on LAN
DASHBOARD_PORT=0.0.0.0:3000:3000

# Auth disabled — private network, single operator
AUTH_DISABLED=true

# Site URL — used for internal redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Daemon URL — daemon runs natively on Mac Mini, containers reach it via host.docker.internal
DAEMON_URL=http://host.docker.internal:3847

# --- Self-hosted Postgres ---
POSTGRES_DB=autoclaude
POSTGRES_USER=autoclaude
POSTGRES_PASSWORD=<database-password>
POSTGRES_PORT=127.0.0.1:5432:5432
AUTO_CLAUDE_DOCKER_DATABASE_URL=postgres://autoclaude:<url-encoded-database-password>@postgres:5432/autoclaude
AUTO_CLAUDE_DATABASE_URL=postgres://autoclaude:<url-encoded-database-password>@127.0.0.1:5432/autoclaude
DAEMON_DATA_BACKEND=postgres
BRIEFING_DATA_BACKEND=postgres

# --- API Keys ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY is NOT needed on Mac Mini — the daemon runs natively
# and uses your Max subscription via claude login. Only needed on Hetzner
# where the daemon runs in Docker without interactive auth.

# --- Dashboard ---
ENCRYPTION_KEY=<32+-char-random-secret>

# --- Daemon ---
DAEMON_SYNC_INTERVAL_MS=60000
