# === Mac Mini Environment ===
# Copy to .env.mac and fill in values:  cp .env.mac.example .env.mac

# Dashboard port binding — exposed on LAN
DASHBOARD_PORT=0.0.0.0:3000:3000

# Auth disabled — private network, single operator
AUTH_DISABLED=true

# Site URL — used for internal redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Daemon URL — daemon runs natively on Mac Mini, containers reach it via host.docker.internal
DAEMON_URL=http://host.docker.internal:3847

# --- Self-hosted Postgres ---
POSTGRES_DB=runforge
POSTGRES_USER=runforge
POSTGRES_PASSWORD=<database-password>
POSTGRES_PORT=127.0.0.1:5432:5432
RUNFORGE_DOCKER_DATABASE_URL=postgres://runforge:<url-encoded-database-password>@postgres:5432/runforge
RUNFORGE_DATABASE_URL=postgres://runforge:<url-encoded-database-password>@127.0.0.1:5432/runforge
DAEMON_DATA_BACKEND=postgres
BRIEFING_DATA_BACKEND=postgres

# --- API Keys ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY is NOT needed on Mac Mini — the daemon runs natively
# and uses your Max subscription via claude login. Only needed on Hetzner
# where the daemon runs in Docker without interactive auth.

# --- Dashboard ---
ENCRYPTION_KEY=<32+-char-random-secret>

# --- Daemon ---
DAEMON_SYNC_INTERVAL_MS=60000

# --- Decision escalation index (optional, default OFF) ---
# Durable ledger of l2-gate decisions (FUNC-AC-DECISION-ESCALATION). Native
# (better-sqlite3) code is loaded ONLY when enabled; a disabled daemon never
# touches it. Enable first on the mini once the live e2e passes.
RUNFORGE_DECISION_INDEX_ENABLED=false
# SQLite file path (relative to the daemon working dir, resolved absolute at boot).
RUNFORGE_DECISION_INDEX_PATH=state/decision-index.sqlite
# base64 AES-256 key for the protected store. If unset, the daemon generates one
# and persists it under state/ on first enabled boot.
RUNFORGE_DECISION_PROTECTED_KEY=
# directory for the protected blob store.
RUNFORGE_DECISION_PROTECTED_DIR=state/decision-protected/
