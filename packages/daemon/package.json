{
  "name": "@auto-claude/daemon",
  "version": "1.0.0",
  "description": "TypeScript daemon that polls GitHub Issues and autonomously implements spec-driven work requests",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --suppressions-location .eslint-suppressions.json",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check src/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@auto-claude/db": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/rest": "^21.0.0",
    "commander": "^13.0.0",
    "gray-matter": "^4.0.3",
    "micromatch": "^4.0.8",
    "minimatch": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
