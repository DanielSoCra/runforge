# Deployment #0 coordinates — copy to deployment0.env (gitignored) and edit.
#   cp deployment0.env.example deployment0.env
#
# Sourced by promote.sh / launch-deployment0.sh / health-poll.sh, and used to
# render the launchd plist templates at install time. Keep this file next to the
# scripts in your ops directory.

# Where the ops scripts + logs + rendered plists live (usually this directory).
RUNFORGE_OPS="$HOME/code/runforge-ops"
# Dedicated runtime clone, pinned to origin/main (never your working checkout).
RUNFORGE_RUNTIME="$HOME/code/runforge-runtime"
# Env file holding secrets (GITHUB_TOKEN fallback, ENCRYPTION_KEY, POSTGRES_PASSWORD).
RUNFORGE_ENV_FILE="$HOME/code/runforge/.env"

# Postgres coordinates for this deployment's own database.
RUNFORGE_DB_ROLE=runforge
RUNFORGE_DB_NAME=runforge_prod
RUNFORGE_DB_HOST=127.0.0.1
RUNFORGE_DB_PORT=5432
# Name of the running postgres container (docker exec target for dump/restore).
RUNFORGE_PG_CONTAINER=runforge-postgres-1

# Daemon control/health port.
RUNFORGE_CONTROL_PORT=3847

# launchd labels for the supervised daemon + external health poller.
RUNFORGE_DAEMON_LABEL=com.runforge.daemon0
RUNFORGE_HEALTH_LABEL=com.runforge.health0

# Values baked into the rendered launchd plists.
RUNFORGE_HOME="$HOME"
RUNFORGE_PATH="/opt/homebrew/bin:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin"
