<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.runforge.daemon0</string>
  <!-- Deployment #0: governed self-hosted runforge daemon. Runs
       launch-deployment0.sh against a dedicated runtime clone + its own DB
       (see deployment0.env). Distinct label from the legacy com.runforge.daemon
       so scripts/install-daemon.sh never clobbers this. Placeholders
       (__OPS_DIR__/__HOME__/__PATH__) are rendered by promote.sh at install. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__OPS_DIR__/launch-deployment0.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__PATH__</string>
    <key>HOME</key>
    <string>__HOME__</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>StandardOutPath</key>
  <string>__OPS_DIR__/logs/daemon0.log</string>
  <key>StandardErrorPath</key>
  <string>__OPS_DIR__/logs/daemon0.log</string>
</dict>
</plist>
