<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.runforge.health0</string>
  <!-- External /health poller for deployment #0 (closes the "wedged but alive"
       gap that launchd KeepAlive cannot see). -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__OPS_DIR__/health-poll.sh</string>
  </array>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__OPS_DIR__/logs/health-poll.err.log</string>
  <key>StandardErrorPath</key>
  <string>__OPS_DIR__/logs/health-poll.err.log</string>
</dict>
</plist>
