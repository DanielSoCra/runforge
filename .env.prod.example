# Dashboard port binding — loopback only, Caddy handles public traffic
DASHBOARD_PORT=127.0.0.1:3000:3000

# GitHub personal access token with repo permissions
# Create at: https://github.com/settings/tokens
# Required scopes: repo (full control)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key (required for CLI adapter in Docker)
# Get from: https://console.anthropic.com/settings/keys
# If using Claude Max subscription locally (not in Docker), this is not needed
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Control-plane token ---
# Shared secret between the daemon control plane and its callers (dashboard,
# briefing-summarizer, concierge, CLI). Required in Docker because the daemon
# binds on 0.0.0.0. The compose file fails fast if this is unset.
RUNFORGE_CONTROL_TOKEN=

# Self-hosted Postgres used by app-owned stores
POSTGRES_DB=runforge
POSTGRES_USER=runforge
POSTGRES_PASSWORD=<database-password>
POSTGRES_PORT=127.0.0.1:5432:5432
RUNFORGE_DOCKER_DATABASE_URL=postgres://runforge:<url-encoded-database-password>@postgres:5432/runforge

# Data backend switches. Runtime data uses app-owned Postgres.
DAEMON_DATA_BACKEND=postgres
BRIEFING_DATA_BACKEND=postgres

# dashboard/.env.local — copy to dashboard/.env.local and fill in values
DAEMON_URL=http://daemon:3847   # Docker service name in production; http://localhost:3847 in dev
ENCRYPTION_KEY=<32+-char-random-secret>
NEXT_PUBLIC_SITE_URL=http://localhost:3000  # change to https://app.example.com in prod

# === dashboard production environment ===
# Copy to .env.prod and fill in values
NEXT_PUBLIC_SITE_URL=https://app.example.com
DAEMON_URL=http://daemon:3847

# GitHub OAuth App credentials (required for GitHub connection feature)
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Set callback URL to: https://<your-domain>/api/auth/github-connection/callback
GITHUB_OAUTH_CLIENT_ID=<client-id-from-github-oauth-app>
GITHUB_OAUTH_CLIENT_SECRET=<client-secret-from-github-oauth-app>

# === daemon production environment (add to existing daemon env) ===
# Daemon bind host — set to 0.0.0.0 in Docker so dashboard container can reach it
# (docker-compose.prod.yml sets this automatically; only needed if running daemon standalone)
# DAEMON_HOST=0.0.0.0
DAEMON_SYNC_INTERVAL_MS=60000

# --- Decision escalation index (optional, default OFF) ---
# Durable ledger of l2-gate decisions (FUNC-AC-DECISION-ESCALATION). Native
# (better-sqlite3) code is loaded ONLY when enabled; a disabled daemon never
# touches it.
RUNFORGE_DECISION_INDEX_ENABLED=false
# SQLite file path. RELATIVE values are resolved against the daemon's STATE
# directory (already `…/state`), so use a BARE name here — a leading `state/`
# would double-resolve to `…/state/state/…` whose parent is never created.
# Use an absolute path to place it elsewhere.
RUNFORGE_DECISION_INDEX_PATH=decision-index.sqlite
# base64 AES-256 key for the protected store. If unset, the daemon generates one
# and persists it in the state directory on first ENABLED boot.
RUNFORGE_DECISION_PROTECTED_KEY=
# directory for the protected blob store. RELATIVE values resolve against the
# state directory — bare name only (see the path note above).
RUNFORGE_DECISION_PROTECTED_DIR=decision-protected/
